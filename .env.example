# ====== 摘要 backend ======
# 'claude-cli' (預設)：用本機 `claude -p` 走你的 Claude Code 訂閱，免額外 API 費
# 'gemini-cli'        ：用本機 `gemini -p` 走你的 Gemini 訂閱
# 'anthropic-api'     ：呼叫 Anthropic API (要付費)
SUMMARIZER=claude-cli
CLAUDE_CLI_MODEL=haiku
# ANTHROPIC_API_KEY=sk-ant-xxxxx  # 只有 SUMMARIZER=anthropic-api 才需要
# ANTHROPIC_MODEL=claude-haiku-4-5

# ====== 抓多遠 ======
# 只回報最近幾小時內的新文章（daily 排程建議 26，留 2 小時 buffer 避免漏抓）
LOOKBACK_HOURS=26

# ====== 排程 (daemon 模式才會用到) ======
CRON_EXPRESSION=0 9 * * *
TZ=Asia/Taipei

# ====== Email (SMTP) ======
# Gmail：建立「應用程式密碼」貼到 SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.account@gmail.com
SMTP_PASS=your_app_password_16chars
EMAIL_FROM="AI Daily News <your.account@gmail.com>"
EMAIL_TO=you@example.com

# ====== LINE Messaging API ======
# 注意：LINE Notify 已於 2025/4/1 停止服務，請改用 Messaging API
# 參考 README 拿 token / userId
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO_USER_ID=

# ====== 開關 ======
ENABLE_EMAIL=true
ENABLE_LINE=true
